{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "lib": ["esnext"],
    "jsx": "react-native",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "outDir": "lib/typescript",
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "lib", "plugin"]
}
